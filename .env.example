# ─── ENVIRONMENT TEMPLATE ────────────────────────────────────────────────────
# Copy this file to .env and fill in values. NEVER commit .env to git.

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production       # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8501
LOG_LEVEL=INFO
VERSION=1.0.0
DEBUG=false

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Encryption ──────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
SECRET_KEY=REPLACE_WITH_SECRET_KEY

# ─── Redis Cache ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
CACHE_ENABLED=true
CACHE_TTL=3600

# ─── Database (PostgreSQL - for audit log & user data) ───────────────────────
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://quantlib:REPLACE_WITH_DB_PASSWORD@localhost:5432/quantlib_pro
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=quantlib_pro
DATABASE_USER=quantlib
DATABASE_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── AWS Configuration ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Prefer IAM roles over access keys in production
# AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
# AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
S3_BACKUP_BUCKET=quantlib-backups
CLOUDWATCH_LOG_GROUP=/ecs/quantlib-pro-task

# ─── GCP Configuration ───────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BACKUP_BUCKET=quantlib-backups

# ─── Azure Configuration ─────────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=quantlib-pro-rg
AZURE_LOCATION=eastus
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=REPLACE_WITH_INSIGHTS_KEY
AZURE_STORAGE_ACCOUNT=quantlibstorage
AZURE_STORAGE_CONTAINER=backups

# ─── Streamlit ───────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=200
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ─── Monitoring & Observability ──────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD
JAEGER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=quantlib-pro

# ─── Error Tracking (Sentry) ─────────────────────────────────────────────────
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── New Relic (Optional) ────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=REPLACE_WITH_NEW_RELIC_KEY
NEW_RELIC_APP_NAME=QuantLib Pro

# ─── Email/SMTP (Alerts & Notifications) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=REPLACE_WITH_EMAIL_PASSWORD
ALERT_EMAIL_RECIPIENTS=admin@your-domain.com,ops@your-domain.com

# ─── Market Data API Keys ────────────────────────────────────────────────────
# Alpha Vantage - https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=REPLACE_WITH_ALPHA_VANTAGE_KEY

# IEX Cloud - https://iexcloud.io/console/tokens
IEX_API_TOKEN=REPLACE_WITH_IEX_TOKEN
IEX_API_VERSION=stable

# Polygon.io - https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=REPLACE_WITH_POLYGON_KEY

# Finnhub - https://finnhub.io/dashboard
FINNHUB_API_KEY=REPLACE_WITH_FINNHUB_KEY

# Quandl/Nasdaq Data Link - https://data.nasdaq.com/account/api
QUANDL_API_KEY=REPLACE_WITH_QUANDL_KEY

# Yahoo Finance (no key required)
YF_ENABLED=true
YFINANCE_MAX_RETRIES=3
YFINANCE_TIMEOUT_SECONDS=30
DEFAULT_DATA_PROVIDER=alpha_vantage

# ─── Security & CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ─── Performance Tuning ──────────────────────────────────────────────────────
WORKERS=4
WORKER_THREADS=2
REQUEST_TIMEOUT=300
MAX_CONNECTIONS=1000

# ─── Data & Cache Directories ────────────────────────────────────────────────
DATA_CACHE_DIR=data/cache
DATA_UPDATE_FREQUENCY=60

# ─── Backup Configuration ────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESS=true

# ─── Health Check Configuration ──────────────────────────────────────────────
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CPU_WARNING_THRESHOLD=75
HEALTH_CPU_CRITICAL_THRESHOLD=90
HEALTH_MEMORY_WARNING_THRESHOLD=75
HEALTH_MEMORY_CRITICAL_THRESHOLD=90
HEALTH_DISK_WARNING_THRESHOLD=75
HEALTH_DISK_CRITICAL_THRESHOLD=90

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_AUTH=true              # Set to true for production
ENABLE_RATE_LIMITING=true     # Set to true for production
ENABLE_AUDIT_LOG=true
ENABLE_GDPR_COMPLIANCE=true   # Set to true before launch
ENABLE_OBSERVABILITY=true     # Set to true in staging/production
FEATURE_PORTFOLIO_OPTIMIZATION=true
FEATURE_RISK_ANALYSIS=true
FEATURE_MONTE_CARLO=true
FEATURE_BACKTESTING=true
FEATURE_LIVE_TRADING=false

# ─── Development Settings (disable in production) ────────────────────────────
AUTO_RELOAD=false
PROFILER_ENABLED=false
USE_MOCK_DATA=false
